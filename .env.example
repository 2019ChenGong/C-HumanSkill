# ============================================================================
# API keys. Two ways to provide them (the code checks env vars FIRST):
#   (A) export as environment variables, e.g.  export DEEPSEEK_API_KEY=sk-...
#   (B) OR create per-provider key files next to this file:
#         openrouter_api.env     ->  OPENROUTER_API_KEY=sk-or-...
#         api_key_deepseek.env   ->  API_KEY=sk-...            (deepseek)
#         openai_api_key.env     ->  sk-proj-...               (bare key, one line)
#         claude_api_key.env     ->  sk-ant-...                (bare key or NAME=value)
#
# A missing key just disables that provider; importing the code never fails.
#   - DeepSeek  : generator / de-id rewriter / utility judge (the cheap workhorse)
#   - Anthropic : haiku LLM-detective + judge + token counting (DRYRUN)
#   - OpenRouter: default router for any other model id
#   - OpenAI    : optional, only if you route gpt-* directly
# ============================================================================

OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
