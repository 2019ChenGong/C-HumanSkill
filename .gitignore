# =============================================================================
# WHITELIST .gitignore — this repo is curated to the CMD key-file set.
# Everything is ignored by default; only the files explicitly un-ignored below
# are tracked. Non-key research scripts stay on disk but are NOT synced.
# =============================================================================

# --- always-ignored (secrets / data / outputs / caches), regardless of rules below ---
*.env
.idea/
.claude/
results/
paper_text.txt
__pycache__/
*.pyc
.ipynb_checkpoints/
.cache/
release/

# --- ignore everything, then allow only the key files ---
/*
!/.gitignore
!/.env.example
!/README.md
!/requirements.txt
!/scripts/
!/src/
!/data/

# data/: README + the V6 RELEASE CARDS (sanitized shared cards + build-stat counters).
# The per-line audit sidecars (*_audit.json) map card lines back to member text and are NEVER tracked
# (see the hard-deny rule at the bottom). Raw datasets stay regenerated-locally.
/data/*
!/data/README.md
!/data/20mad/
/data/20mad/*
!/data/20mad/cmd_shared_cards_mad__v6min.json
!/data/20mad/cmd_shared_cards_mad__v6min_stats.json
!/data/se/
/data/se/*
!/data/se/cmd_shared_cards_cv__v6min.json
!/data/se/cmd_shared_cards_cv__v6min_stats.json
!/data/enron/
/data/enron/*
!/data/enron/cmd_shared_cards__v6min.json
!/data/enron/cmd_shared_cards__v6min_stats.json

# src/: only the key modules
/src/*
!/src/__init__.py
!/src/llm.py
!/src/attrib_metrics.py

# scripts/: only the CMD key set
/scripts/*
# CMD core
!/scripts/cmd_gate.py
!/scripts/cmd_gate_score.py
!/scripts/cmd_openworld.py
!/scripts/cmd_openworld_score.py
!/scripts/cmd_utility.py
!/scripts/cmd_batch.py
